#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<'EOF'
CoolifyBR unified CLI

Usage:
  coolifybr <command> [args...]

Commands:
  backup                 Run coolify-backup.sh
  restore                Run coolify-restore.sh
  pull-run               Run one remote pull backup job
  pull-run-jobs          Run all remote pull jobs in a config directory
  pull-verify            Verify a pulled snapshot
  pull-install-cron      Install cron for one remote pull job
  pull-install-jobs-cron Install cron entries for all remote pull jobs
  install                Run the installer/bootstrap script
  help                   Show this help

Examples:
  ./coolifybr backup --mode full
  ./coolifybr restore --file /tmp/backup.tar.gz
  CONFIG_FILE=/root/.config/coolifybr/jobs/app.env ./coolifybr pull-run
  CONFIG_DIR=/root/.config/coolifybr/jobs ./coolifybr pull-run-jobs
  ./coolifybr pull-verify /srv/backups/app 20260415T021924Z
  ./coolifybr install --profile backup-host
EOF
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
    shift
fi

case "$command" in
    backup)
        exec "$SCRIPT_DIR/coolify-backup.sh" "$@"
        ;;
    restore)
        exec "$SCRIPT_DIR/coolify-restore.sh" "$@"
        ;;
    pull-run)
        exec "$SCRIPT_DIR/ops/remote-pull-backup.sh" "$@"
        ;;
    pull-run-jobs)
        exec "$SCRIPT_DIR/ops/run-remote-pull-jobs.sh" "$@"
        ;;
    pull-verify)
        exec "$SCRIPT_DIR/ops/verify-remote-pull-backup.sh" "$@"
        ;;
    pull-install-cron)
        exec "$SCRIPT_DIR/ops/install-remote-pull-cron.sh" "$@"
        ;;
    pull-install-jobs-cron)
        exec "$SCRIPT_DIR/ops/install-remote-pull-jobs-cron.sh" "$@"
        ;;
    install)
        exec "$SCRIPT_DIR/scripts/install.sh" "$@"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $command" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
esac
