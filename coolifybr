#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<'EOF'
CoolifyBR unified CLI

Usage:
  coolifybr <command> [subcommand] [args...]

Commands:
  backup                  Run local/source backup flow
  restore                 Run restore flow
  install                 Bootstrap CoolifyBR on this machine
  doctor                  Check machine readiness
  init job                Create a new remote pull job config
  pull run                Run one remote pull backup job
  pull verify             Verify a pulled snapshot
  pull jobs run           Run all remote pull jobs from a directory
  cron install            Install cron for one remote pull job
  cron install-jobs       Install cron entries for every job config
  help                    Show this help

Legacy aliases:
  pull-run
  pull-run-jobs
  pull-verify
  pull-install-cron
  pull-install-jobs-cron

Examples:
  coolifybr backup --mode full
  coolifybr restore --file /tmp/backup.tar.gz
  coolifybr install --profile backup-host
  coolifybr doctor --profile backup-host
  coolifybr init job --name app-1
  CONFIG_FILE=/root/.config/coolifybr/jobs/app-1.env coolifybr pull run
  CONFIG_DIR=/root/.config/coolifybr/jobs coolifybr pull jobs run
  coolifybr cron install
EOF
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
    shift
fi

case "$command" in
    backup)
        exec "$SCRIPT_DIR/coolify-backup.sh" "$@"
        ;;
    restore)
        exec "$SCRIPT_DIR/coolify-restore.sh" "$@"
        ;;
    install)
        exec "$SCRIPT_DIR/scripts/install.sh" "$@"
        ;;
    doctor)
        exec "$SCRIPT_DIR/scripts/doctor.sh" "$@"
        ;;
    init)
        sub="${1:-}"
        if [[ $# -gt 0 ]]; then
            shift
        fi
        case "$sub" in
            job)
                exec "$SCRIPT_DIR/scripts/init-job.sh" "$@"
                ;;
            *)
                echo "Unknown init subcommand: ${sub:-<empty>}" >&2
                usage >&2
                exit 1
                ;;
        esac
        ;;
    pull)
        sub="${1:-}"
        if [[ $# -gt 0 ]]; then
            shift
        fi
        case "$sub" in
            run)
                exec "$SCRIPT_DIR/ops/remote-pull-backup.sh" "$@"
                ;;
            verify)
                exec "$SCRIPT_DIR/ops/verify-remote-pull-backup.sh" "$@"
                ;;
            jobs)
                sub2="${1:-}"
                if [[ $# -gt 0 ]]; then
                    shift
                fi
                case "$sub2" in
                    run)
                        exec "$SCRIPT_DIR/ops/run-remote-pull-jobs.sh" "$@"
                        ;;
                    *)
                        echo "Unknown pull jobs subcommand: ${sub2:-<empty>}" >&2
                        usage >&2
                        exit 1
                        ;;
                esac
                ;;
            *)
                echo "Unknown pull subcommand: ${sub:-<empty>}" >&2
                usage >&2
                exit 1
                ;;
        esac
        ;;
    cron)
        sub="${1:-}"
        if [[ $# -gt 0 ]]; then
            shift
        fi
        case "$sub" in
            install)
                exec "$SCRIPT_DIR/ops/install-remote-pull-cron.sh" "$@"
                ;;
            install-jobs)
                exec "$SCRIPT_DIR/ops/install-remote-pull-jobs-cron.sh" "$@"
                ;;
            *)
                echo "Unknown cron subcommand: ${sub:-<empty>}" >&2
                usage >&2
                exit 1
                ;;
        esac
        ;;
    pull-run)
        exec "$SCRIPT_DIR/ops/remote-pull-backup.sh" "$@"
        ;;
    pull-run-jobs)
        exec "$SCRIPT_DIR/ops/run-remote-pull-jobs.sh" "$@"
        ;;
    pull-verify)
        exec "$SCRIPT_DIR/ops/verify-remote-pull-backup.sh" "$@"
        ;;
    pull-install-cron)
        exec "$SCRIPT_DIR/ops/install-remote-pull-cron.sh" "$@"
        ;;
    pull-install-jobs-cron)
        exec "$SCRIPT_DIR/ops/install-remote-pull-jobs-cron.sh" "$@"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $command" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
esac
