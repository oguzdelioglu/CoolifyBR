VERIFY_VOLUME_ARCHIVES="true"
DELETE_REMOTE_ARCHIVE_AFTER_PULL="false"
DELETE_LOCAL_ARCHIVE_AFTER_EXTRACT="false"
RETENTION_DAILY="7"
RETENTION_WEEKLY="4"
RETENTION_MONTHLY="6"
