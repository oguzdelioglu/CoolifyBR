# ============================================================
# CoolifyBR - Configuration
# Copy this file and adjust values for your environment
# ============================================================

# Coolify API Settings
# Get your token from: Coolify Dashboard → Keys & Tokens → API Tokens
COOLIFY_API_BASE="http://localhost:8000"
COOLIFY_API_TOKEN=""

# Remote Transfer Defaults
TRANSFER_HOST=""
TRANSFER_USER="root"
TRANSFER_PORT="22"
TRANSFER_KEY=""

# Backup Output Directory
# OUTPUT_DIR="./backups"

# Coolify Database Settings (usually no need to change)
# COOLIFY_DB_CONTAINER="coolify-db"
# COOLIFY_DB_USER="coolify"
# COOLIFY_DB_NAME="coolify"
